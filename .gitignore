# ============================================================================
# FPGA-Litho 项目 Git Ignore 配置
# ============================================================================
# 参考：https://github.com/github/gitignore/blob/main/C++.gitignore
# ============================================================================

# ============================================================================
# 编译产物
# ============================================================================
# Object files
*.o
*.ko
*.obj
*.elf

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo
*.dll
*.dylib

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# 项目可执行文件
tb_tcc
test_*
klitho_tcc
klitho_socs
socs_host
tb_socs_simple_test

# ============================================================================
# HLS工作目录（vitis-run生成）
# ============================================================================
# HLS工程目录（不提交，太大）
# 命名规则：由顶层函数名或--work_dir参数决定
# 例如：fft_2d_forward_32, socs_simple, hls/socs_fixed 等

# 通配符匹配所有HLS工程目录（项目级）
*_proj/
*_hls_proj/
hls_*/
*.hlsproj/
solution*/
fft_2d_forward_32*/
*_comp/
*_test/
*_vpp/

# 通配符匹配source子目录下的HLS工作目录
source/*/**_proj/
source/*/hls/
source/*/_ide/
source/*/logs/
source/SOCS_HLS/fft_2d_forward_32*/
source/SOCS_HLS/socs_axilite_final/

# 根目录HLS工作目录
hls/

# HLS编译产物
*.log
*.rpt
*.xml
*.db
*.adb
*.ipynb

# HLS仿真产物
csim/build/
csim/report/
cosim/
syn/
impl/

# HLS日志
cosim_log.txt

# ============================================================================
# Vivado工程文件
# ============================================================================
# Vivado工程目录
*.xpr/
*.runs/
*.srcs/
*.hw/
*.sim/
*.cache/
.Xil/

# Vivado编译产物
*.bit
*.ltx
*.mcs
*.prm
*.bin

# Vivado日志
*.jou
*.log
*.str
*.xml

# Vivado IP缓存
ip_repo/
*.zip

# HLS IP 导出目录
output/SOCS_IP/

# ============================================================================
# IDE和编辑器
# ============================================================================
# VSCode
.vscode/
*.code-workspace

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================================================
# 操作系统临时文件
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ============================================================================
# Python
# ============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ============================================================================
# 项目特定输出文件
# ============================================================================
# 验证输出日志
verify_output.log

# 验证产物
verification/__pycache__/
verification/src/__pycache__/

# ============================================================================
# 临时测试文件
# ============================================================================
# 测试输出
test_output/
temp_*
tmp_*

# Host输出目录
source/host/output/

# 输出目录（除了verification golden数据）
output/verification/png/
*.png
!verification/png/*.png

# 临时二进制文件（Phase 5+可提交golden数据）
# golden/*.bin 在Phase 1-4需要保留
# output/reference/ 在Phase 0需要保留（CPU参考输出）

# ============================================================================
# 项目特定忽略规则
# ============================================================================
# 不提交大型二进制文件（golden数据除外）
# input/mask/*.bin
# input/source/*.bin
# output/image.bin
# output/kernels/*.bin

# 不提交HLS临时产物
source/TCC_HLS/hls_litho_proj/

# 不提交HLS数据文件
source/TCC_HLS/data/

# ============================================================================
# 白名单文件（强制提交）
# ============================================================================
# 即使符合忽略规则也提交：
!source/TCC_HLS/hls/tb/golden/*.bin
!output/reference/*.bin
!output/reference/kernels/*.bin
!input/config/*.json
!input/*.md

# ============================================================================
# 注释说明
# ============================================================================
# Phase 0-4：提交Golden测试数据（hls/tb/golden/*.bin）
# Phase 5+：不提交大型输出文件，通过运行生成
# 参考：.github/copilot-instructions.md中的验收标准
_.md
_.md
